local prompt = script.Parent:WaitForChild("ProximityPrompt")

local ITEM_NAME = "SolarPanel_V1"
local COST = 50

-- Updated UI text
prompt.ObjectText = ITEM_NAME
prompt.ActionText = "Buy for $" .. COST .. " Money" -- Refreshed text

prompt.Triggered:Connect(function(player)
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local RequestPurchase = ReplicatedStorage.TycoonEvents.RequestPurchase
    
    -- Request the purchase from the server
    RequestPurchase:FireServer(COST, workspace:FindFirstChild(ITEM_NAME), script.Parent)
end)
