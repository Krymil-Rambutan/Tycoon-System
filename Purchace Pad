-- Purchase Pad Script
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RequestPurchase = ReplicatedStorage:WaitForChild("TycoonEvents"):WaitForChild("RequestPurchase")

local pad = script.Parent
local prompt = pad:WaitForChild("ProximityPrompt")

-- CONFIGURATION
local ITEM_NAME = "BasicGenerator" -- The name of the object to unlock
local COST = 100
-- Reference the object this pad unlocks (it should be invisible in Workspace somewhere)
local TARGET_OBJECT = workspace:FindFirstChild(ITEM_NAME) 

prompt.ObjectText = ITEM_NAME
prompt.ActionText = "Purchase for $" .. COST

prompt.Triggered:Connect(function(player)
	if TARGET_OBJECT then
		-- Send the request to the server script
		RequestPurchase:FireServer(COST, TARGET_OBJECT, pad)
	end
end)
