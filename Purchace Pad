local yieldPerTick = 10 
local tickRate = 1

while true do
    task.wait(tickRate)
    
    for _, player in pairs(game.Players:GetPlayers()) do
        local stats = player:FindFirstChild("leaderstats")
        if stats then
            local moneyStat = stats:FindFirstChild("Money")
            if moneyStat then
                moneyStat.Value += yieldPerTick
            end
        end
    end
end
