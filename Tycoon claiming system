local claimPart = script.Parent
local tycoonFolder = claimPart.Parent
local ownerValue = tycoonFolder:WaitForChild("Owner") -- Create an ObjectValue named "Owner"

claimPart.Touched:Connect(function(hit)
    local character = hit.Parent
    local player = game.Players:GetPlayerFromCharacter(character)

    if player and ownerValue.Value == nil then
        -- Check if player already owns a tycoon
        if player:FindFirstChild("HasTycoon") then return end

        -- Assign Ownership
        ownerValue.Value = player
        claimPart.Transparency = 1
        claimPart.CanCollide = false
        
        -- Create a tag on player to prevent double-claiming
        local tag = Instance.new("BoolValue")
        tag.Name = "HasTycoon"
        tag.Parent = player
        
        print(player.Name .. " has claimed the Electric Plant!")
    end
end)
