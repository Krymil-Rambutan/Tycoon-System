local DataStoreService = game:GetService("DataStoreService")
local moneyData = DataStoreService:GetDataStore("PlayerMoney_v1")

game.Players.PlayerAdded:Connect(function(player)
    local leaderstats = Instance.new("Folder")
    leaderstats.Name = "leaderstats"
    leaderstats.Parent = player

    local money = Instance.new("IntValue")
    money.Name = "Money"
    money.Value = 0
    money.Parent = leaderstats

    -- Load Data
    local success, savedMoney = pcall(function()
        return moneyData:GetAsync(player.UserId)
    end)

    if success and savedMoney then
        money.Value = savedMoney
    end
end)

game.Players.PlayerRemoving:Connect(function(player)
    local success, err = pcall(function()
        -- Reference the new "Money" object
        moneyData:SetAsync(player.UserId, player.leaderstats.Money.Value)
    end)
end)
