local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RequestPurchase = ReplicatedStorage.TycoonEvents.RequestPurchase

-- 1. Create Leaderstats (Electric Units)
Players.PlayerAdded:Connect(function(player)
	local leaderstats = Instance.new("Folder")
	leaderstats.Name = "leaderstats"
	leaderstats.Parent = player

	local electricUnits = Instance.new("IntValue")
	electricUnits.Name = "Electric Units"
	electricUnits.Value = 0 -- Starting Balance
	electricUnits.Parent = leaderstats
end)

-- 2. Handle Purchases
RequestPurchase.OnServerEvent:Connect(function(player, cost, itemToUnlock, padObject)
	local currency = player.leaderstats["Electric Units"]
	
	if currency.Value >= cost then
		currency.Value -= cost
		
		-- Logic to show the item
		itemToUnlock.Transparency = 0
		itemToUnlock.CanCollide = true
		
		-- Clean up the purchase pad
		padObject:Destroy()
		print(player.Name .. " bought " .. itemToUnlock.Name)
	else
		print("Insufficient Electric Units!")
	end
end)
